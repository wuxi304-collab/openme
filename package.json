{
  "name": "openme-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "OpenMe Qiwu is a local-first desktop workspace for previewing and inspecting everyday files — published by Gangtie Shuxu (钢铁私塾).",
  "main": "electron/main.js",
  "author": "Gangtie Shuxu (钢铁私塾)",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"electron .\"",
    "dist": "npm run build && electron-builder",
    "test": "vitest run",
    "test:watch": "vitest",
    "audit:i18n": "node scripts/audit-i18n.mjs",
    "support:matrix": "node scripts/generate-support-matrix.mjs"
  },
  "dependencies": {
    "@mlightcad/cad-simple-viewer": "^1.5.7",
    "@mlightcad/libredwg-web": "^0.7.7",
    "@monaco-editor/react": "^4.7.0",
    "@xmldom/xmldom": "^0.9.10",
    "electron-log": "^5.2.4",
    "highlight.js": "^11.10.0",
    "jszip": "^3.10.1",
    "mammoth": "^1.8.0",
    "marked": "^15.0.0",
    "music-metadata": "^11.13.0",
    "occt-import-js": "^0.0.23",
    "papaparse": "^5.5.2",
    "pdfjs-dist": "^4.9.155",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "read-excel-file": "^9.2.0",
    "three": "^0.172.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/papaparse": "^5.3.15",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.172.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "electron": "^43.1.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.9"
  },
  "build": {
    "appId": "com.openme.desktop",
    "productName": "OpenMe Qiwu",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icons/icon.ico"
    },
    "portable": {
      "artifactName": "OpenMe-Qiwu-${version}-portable-x64.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "OpenMe Qiwu",
      "artifactName": "OpenMe-Qiwu-${version}-setup-x64.${ext}",
      "deleteAppDataOnUninstall": false,
      "installerIcon": "public/icons/icon.ico",
      "uninstallerIcon": "public/icons/icon.ico",
      "installerHeaderIcon": "public/icons/icon.ico"
    },
    "extraResources": [
      {
        "from": "cad-host/publish",
        "to": "cad-host",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "license": "MIT"
}
